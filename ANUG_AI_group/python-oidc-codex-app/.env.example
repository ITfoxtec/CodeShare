FLASK_SECRET_KEY=replace-with-a-long-random-secret
APP_BASE_URL=http://localhost:5000
SESSION_COOKIE_SECURE=false

FOXIDS_AUTHORITY=https://your-tenant.foxids.com
FOXIDS_CLIENT_ID=replace-with-your-client-id
FOXIDS_CLIENT_SECRET=replace-with-your-client-secret
FOXIDS_USE_DISCOVERY=true
# Use false only for local self-signed FoxIDs development, or set a PEM/CRT path.
FOXIDS_VERIFY_TLS=true