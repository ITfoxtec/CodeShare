@page
@model IndexModel
@{
    ViewData["Title"] = "FoxIDs sign-in sample";
}

<div class="py-4">
    <div class="mb-4 text-center">
        <h1 class="display-5">FoxIDs OpenID Connect</h1>
        <p class="lead mb-0">This sample signs users in with FoxIDs, keeps the session in a server-side web app cookie, and only renders protected data for authenticated users.</p>
    </div>

    @if (!Model.IsAuthenticated)
    {
        <div class="alert alert-info" role="alert">
            You are not signed in. Use the Log in button in the header to start the OpenID Connect code flow.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-5">
                <section class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h4">Protected data</h2>
                        <p class="text-muted">This content is only fetched and rendered after the authenticated cookie is established.</p>
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.ProtectedData)
                            {
                                <li class="list-group-item">@item</li>
                            }
                        </ul>
                    </div>
                </section>
            </div>

            <div class="col-lg-7">
                <section class="card h-100 border-warning shadow-sm">
                    <div class="card-body">
                        <h2 class="h4">Temporary debug claims view</h2>
                        <p class="fw-semibold text-warning-emphasis">Remove this claims display before shipping to production.</p>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col">Claim type</th>
                                        <th scope="col">Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var claim in Model.DebugClaims)
                                    {
                                        <tr>
                                            <td><code>@claim.Type</code></td>
                                            <td class="text-break"><code>@claim.Value</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    }
</div>
